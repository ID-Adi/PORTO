# PostgreSQL connection string for Drizzle / Better Auth
DATABASE_URL=postgresql://porto:porto_secret@localhost:5433/porto_db

# Redis (OPSIONAL) — cache scene canvas agar load workflow berulang cepat.
# Kosongkan untuk menonaktifkan cache; app tetap berjalan normal tanpa Redis.
# Contoh: redis://localhost:6379  atau  rediss://user:pass@host:6380
REDIS_URL=

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:4002

# Hono server port (juga port internal yang dipakai Caddy reverse_proxy
# ke container porto-backend di prod)
PORT=4002

# Frontend origin allowed by CORS
FRONTEND_URL=http://localhost:3001

# Admin user (used by `pnpm db:seed:admin` and the protectedProcedure check)
ADMIN_EMAIL=admin@porto.dev
ADMIN_PASSWORD=replace-me

# Encrypts API keys saved from /admin/ai-settings. Generate:
# openssl rand -base64 32
AI_CONFIG_ENCRYPTION_KEY=replace-with-32-byte-random-secret

# Raindrop.io (optional) — token for the "Currently Reading" homepage section.
# Get a test token at https://app.raindrop.io/settings/integrations.
# Leave empty to fall back to the static reading list in landing-content.ts.
RAINDROP_API_TOKEN=
# Collection ID to pull from. Use 0 for all bookmarks, or a specific collection ID.
RAINDROP_COLLECTION_ID=0

# N8N webhook untuk fitur /tools (Generate Image via Gemini).
# Copy URL dari node Webhook di workflow GEMINI 3.1 GENERATE.
N8N_WEBHOOK_URL=https://n8n.example.com/webhook/porto-tools-image
# Shared secret untuk header X-PORTO-Token (nilai sama dengan credential
# Header Auth di N8N). Generate: `openssl rand -hex 32`.
N8N_WEBHOOK_TOKEN=replace-with-32-char-random

# N8N webhook untuk fitur /tools Generate Video (Veo 3 image-to-video).
# Start webhook menerima firstFrame (+ optional lastFrame) lalu mengembalikan
# operationName Veo. Status webhook polling fetchPredictOperation.
# Token reuse N8N_WEBHOOK_TOKEN.
N8N_VIDEO_WEBHOOK_URL=https://n8n.example.com/webhook/porto-video-start
N8N_VIDEO_STATUS_WEBHOOK_URL=https://n8n.example.com/webhook/porto-video-status

# Base URL backend yang publik (dipakai untuk membangun URL absolut
# /uploads/* yang dikirim ke frontend Vercel). Kosongkan di dev kalau
# backend & frontend sama-origin. Contoh prod: https://api.pawa.my.id
PUBLIC_BACKEND_URL=https://api.example.com

# COOKIE_DOMAIN untuk cross-subdomain cookie (Better-Auth advanced).
# Set ke parent domain dengan leading dot (mis. `.pawa.my.id`). Kosong
# = same-origin only (dev default).
COOKIE_DOMAIN=

# ── Mailcow SMTP ──────────────────────────────────────────────
# Digunakan untuk mengirim email reset password dan notifikasi.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="PORTO <noreply@example.com>"
