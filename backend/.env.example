# PostgreSQL connection string for Drizzle / Better Auth
DATABASE_URL=postgresql://porto:porto_secret@localhost:5433/porto_db

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:4001

# Hono server port
PORT=4001

# Admin user (used by `pnpm db:seed:admin` and the protectedProcedure check)
ADMIN_EMAIL=admin@porto.dev
ADMIN_PASSWORD=replace-me
