# Variabel yang dibaca oleh docker-compose.yml (root).
# Salin: `cp .env.example .env` lalu isi nilai rahasia.
# File `.env` di-gitignore — JANGAN commit.

# Kredensial Postgres untuk service `postgres` di docker-compose.
POSTGRES_USER=porto
POSTGRES_PASSWORD=replace-with-strong-secret   # openssl rand -base64 24
POSTGRES_DB=porto_db

# DATABASE_URL untuk service `backend` (host = container_name `porto-postgres`).
# Harus konsisten dengan POSTGRES_USER / POSTGRES_PASSWORD di atas.
BACKEND_DATABASE_URL=postgresql://porto:replace-with-strong-secret@porto-postgres:5432/porto_db
