{
  "name": "porto-monolith",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "install:frontend": "pnpm --dir frontend install",
    "install:backend": "pnpm --dir backend install",
    "dev:frontend": "pnpm --dir frontend dev",
    "build:frontend": "pnpm --dir frontend build",
    "lint:frontend": "pnpm --dir frontend lint",
    "db:generate": "pnpm --dir backend db:generate",
    "db:migrate": "pnpm --dir backend db:migrate",
    "db:studio": "pnpm --dir backend db:studio"
  }
}
